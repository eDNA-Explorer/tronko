    "decomp_max_sizes": [500, 1000, 2000, 5000, 0],
    "decomp_max_diams": [0],
    "decomp_min_size": 3,
    "decomp_strategy": "centroid",

    "_comment_stage3": "Per-partition tree quality",
    "fasttree_gamma": [false, true],
    "famsa_threads": 4,
    "partition_workers": 3,

    "_comment_stage4": "tronko-build — no SP filtering (already shown to be best)",
    "sp_thresholds": [0],
    "tronko_threads": 12,

    "threads": 12
